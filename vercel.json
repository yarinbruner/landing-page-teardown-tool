{
  "buildCommand": "npm --prefix web install && npm --prefix web run build",
  "outputDirectory": "web/dist",
  "framework": null,
  "functions": {
    "api/expert-teardown.js": {
      "includeFiles": "TEARDOWN_EXPERT.md"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
